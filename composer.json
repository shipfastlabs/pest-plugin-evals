{
    "name": "shipfastlabs/pest-plugin-eval",
    "description": "A PestPHP plugin for evaluating Laravel AI SDK agents with LLM-as-judge, semantic similarity, and deterministic scorers",
    "keywords": [
        "php",
        "framework",
        "pest",
        "unit",
        "test",
        "testing",
        "plugin",
        "eval",
        "ai",
        "llm",
        "laravel"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Pushpak Chhajed",
            "email": "pushpak1300@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/ai": "^0.1|^0.2|^0.3|^0.4",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin": "^4.0.0"
    },
    "require-dev": {
        "laravel/framework": "^12.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest-dev-tools": "^4.1.0"
    },
    "autoload": {
        "psr-4": {
            "ShipFastLabs\\PestEval\\": "src/"
        },
        "files": [
            "src/Autoload.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ShipFastLabs\\PestEval\\Tests\\": "tests/"
        }
    },
    "extra": {
        "pest": {
            "plugins": [
                "ShipFastLabs\\PestEval\\Plugin"
            ]
        },
        "laravel": {
            "providers": [
                "ShipFastLabs\\PestEval\\EvalServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "refactor": "rector",
        "lint": "pint",
        "test:refactor": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "pest --colors=always",
        "test": [
            "@test:refactor",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    }
}
